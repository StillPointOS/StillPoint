"use client";
import { clsx } from "clsx";

interface CardProps {
  children: React.ReactNode;
  className?: string;
  variant?: "glass" | "solid" | "dark";
  padding?: "sm" | "md" | "lg";
}

const VARIANTS = {
  glass: "glass",
  solid: "bg-white border border-stone-200 shadow-sm",
  dark: "bg-stone-900 text-white",
};

const PADDING = {
  sm: "p-4",
  md: "p-6",
  lg: "p-8",
};

export function Card({ children, className, variant = "glass", padding = "md" }: CardProps) {
  return (
    <div className={clsx("rounded-2xl", VARIANTS[variant], PADDING[padding], className)}>
      {children}
    </div>
  );
} 

